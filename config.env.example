# ── Telegram ────────────────────────────────────────────────
BOT_TOKEN=7123456789:AAF_xxxxxxxxxxxxxxxxxxxxxxx
CHANNEL_ID=-1001234567890

# ── Переводчики ──────────────────────────────────────────────
DEEPL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx
OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx   # для редактуры шагов 1 и 3
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
FORMAT_RAG_ENABLED=1
FORMAT_RAG_MODEL=meta-llama/llama-3.3-70b-instruct:free
FORMAT_EXAMPLES_PATH=format_model/examples.jsonl
FORMAT_RAG_TOP_K=4
FORMAT_RAG_MAX_EXAMPLE_TEXT=1200
FORMAT_RAG_TIMEOUT=18
FORMAT_HARD_CASES_PATH=format_model/hard_cases.jsonl

# ── Шаг 1: Twitter по ключевым словам ───────────────────────
# Nitter RSS ленты — через запятую без пробелов
# Формат для поиска по слову: https://nitter.net/search?f=tweets&q=СЛОВО&since=1d
# Формат для аккаунта:        https://nitter.net/АККАУНТ/rss
STEP1_RSS_URLS=https://nitter.net/search?f=tweets&q=nico+paz/rss,https://nitter.net/search?f=tweets&q=nicopaz/rss

# Ключевые слова для фильтрации (через запятую)
STEP1_KEYWORDS=nico paz,nicopaz,nico_paz,creator

# ── Шаг 2: Instagram ────────────────────────────────────────
# JSON Feed от RSS.app
STEP2_RSSAPP_URL=https://rss.app/feeds/v1.1/ВАШ_FEED_ID.json

# ── Шаг 3: Twitter-аккаунты ─────────────────────────────────
# Аккаунты через запятую (без @)
STEP3_ACCOUNTS=Reuters,BBCWorld,AP
