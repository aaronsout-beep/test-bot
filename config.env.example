# Пример переменных окружения для GitHub Actions.
# Это НЕ файл с настоящими ключами. Настоящие значения добавляйте в GitHub:
# Settings -> Secrets and variables -> Actions -> New repository secret.

# ── 1. Обязательно: Telegram ────────────────────────────────

# Токен бота от @BotFather.
BOT_TOKEN=7123456789:AAF_xxxxxxxxxxxxxxxxxxxxxxx

# ID канала. Обычно начинается с -100.
CHANNEL_ID=-1001234567890

# Канал для служебных алертов. Можно оставить пустым.
ALERT_CHANNEL_ID=

# Имя бота в служебных сообщениях.
BOT_NAME=KendryPaezBot


# ── 2. Обязательно: перевод ─────────────────────────────────

# Ключ DeepL API. Без него bot.py не запустится.
DEEPL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx


# ── 3. Gemini: глоссарий, литературная редактура, верстка ───

# Ключ Gemini. Если оставить пустым, DeepL будет работать, но AI-редактура
# и Gemini-верстка будут пропущены.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Базовый URL Gemini. Обычно не трогать.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Модель Gemini для проверки глоссария и Telegram-верстки.
LAYOUT_AI_MODEL=gemini-2.5-flash-lite

# Максимальная длина текста для Gemini-проверки верстки.
LAYOUT_AI_MAX_CHARS=3200

# Таймаут Gemini-проверки верстки в секундах.
LAYOUT_AI_TIMEOUT=12

# Включить литературную редактуру русского текста:
# 1 = включено, 0 = выключено.
STYLE_EDIT_ENABLED=1

# Модель для литературной редактуры. Если пусто, используется LAYOUT_AI_MODEL.
STYLE_EDIT_MODEL=gemini-2.5-flash-lite

# Максимальная длина текста для литературной редактуры.
STYLE_EDIT_MAX_CHARS=1800

# Таймаут литературной редактуры в секундах.
STYLE_EDIT_TIMEOUT=18


# ── 4. OpenRouter: дубли и RAG-верстка ──────────────────────

# Ключ OpenRouter. Если пустой, AI-дубли и RAG-верстка будут пропущены.
OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Модель для AI-проверки смысловых дублей.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# RAG-проверка верстки:
# 1 = включено, 0 = выключено.
FORMAT_RAG_ENABLED=1

# Модель для RAG-проверки верстки. Обычно можно оставить как OPENROUTER_MODEL.
FORMAT_RAG_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Файл с примерами хорошей верстки.
FORMAT_EXAMPLES_PATH=format_model/examples.jsonl

# Сколько похожих примеров брать для RAG.
FORMAT_RAG_TOP_K=4

# Максимальная длина одного примера.
FORMAT_RAG_MAX_EXAMPLE_TEXT=1200

# Таймаут RAG в секундах.
FORMAT_RAG_TIMEOUT=18

# Куда сохранять опасные/отклоненные случаи.
FORMAT_HARD_CASES_PATH=format_model/hard_cases.jsonl


# ── 5. Подпись под постами ──────────────────────────────────

# Хэштег без #.
SIGNATURE_HASHTAG=KendryPaez

# Ссылка в подписи.
SIGNATURE_URL=https://t.me/your_channel

# Текст ссылки.
SIGNATURE_URL_TEXT=Follow us


# ── 6. Шаг 1: Twitter/X по ключевым словам через Scweet ─────

# Ключевые слова через запятую.
STEP1_KEYWORDS=kendry páez,kendry paez,kendrypaez,kendrypaez

# Если указать аккаунты, поиск будет только по ним. Если оставить пустым,
# поиск будет шире.
STEP1_ACCOUNTS=

# Сколько твитов просматривать за запуск.
STEP1_LIMIT=50

# Auth token для Scweet. Нужен для шагов 1 и 3.
SCWEET_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Proxy для Scweet. Если не используете proxy, оставить пустым.
SCWEET_PROXY=

# Получать manifest Scweet при запуске:
# 1 = да, 0 = нет.
SCWEET_MANIFEST_SCRAPE_ON_INIT=1


# ── 7. Шаг 2: Instagram-аккаунты через Apify ────────────────

# Ключ Apify.
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxx

# Instagram-аккаунты через запятую, без @.
STEP2_INSTAGRAM_ACCOUNTS=kendrypaez,chelseafc

# Actor Apify для Instagram-постов. Обычно не трогать.
APIFY_INSTAGRAM_ACTOR=apify~instagram-post-scraper

# Сколько результатов брать.
APIFY_INSTAGRAM_RESULTS_LIMIT=10

# Возраст постов.
APIFY_INSTAGRAM_ONLY_NEWER_THAN=2 days

# Уровень данных. Обычно detailedData.
APIFY_INSTAGRAM_DATA_DETAIL_LEVEL=detailedData

# Пропускать закрепленные посты:
# 1 = да, 0 = нет.
APIFY_INSTAGRAM_SKIP_PINNED=1

# Если нужен ручной JSON input для Apify, вставлять сюда. Обычно пусто.
APIFY_INSTAGRAM_INPUT_JSON=

# Таймаут Apify в секундах.
APIFY_RUN_TIMEOUT=180

# Лимиты Apify. Можно оставить пустыми.
APIFY_MAX_ITEMS=
APIFY_MAX_TOTAL_CHARGE_USD=


# ── 8. Шаг 3: Twitter/X конкретные аккаунты ─────────────────

# Аккаунты через запятую, без @.
STEP3_ACCOUNTS=FabrizioRomano,DiarioOleEc

# Сколько постов можно опубликовать.
STEP3_LIMIT=20

# Сколько постов просматривать.
STEP3_SCAN_LIMIT=50

# Использовать Nitter fallback, если Scweet дал старые данные:
# 1 = да, 0 = нет.
STEP3_NITTER_FALLBACK=1

# Через сколько часов данные Scweet считать устаревшими.
STEP3_NITTER_STALE_HOURS=12


# ── 9. Шаг 4: Instagram по хэштегам ─────────────────────────

# Хэштеги через запятую, без #.
STEP4_HASHTAGS=kendrypaez,chelsea

# Actor Apify для Instagram-хэштегов. Обычно не трогать.
APIFY_HASHTAG_ACTOR=apify~instagram-hashtag-scraper

# Сколько результатов брать.
APIFY_HASHTAG_RESULTS_LIMIT=10

# Возраст постов.
APIFY_HASHTAG_ONLY_NEWER_THAN=2 days

# Подпись только для шага 4.
STEP4_SIGNATURE=#KendryPaez | Follow us

# Префикс в начале поста шага 4. Можно оставить пустым.
STEP4_PREFIX=

# Если заполнено, шаг 4 публикует посты только от этих аккаунтов.
STEP4_ALLOWED_ACCOUNTS=kendrypaez,chelseafc


# ── 10. VK / MAX cross-posting. Можно оставить пустым ───────

VK_ACCESS_TOKEN=
VK_OWNER_ID=
VK_API_VERSION=5.199
VK_FROM_GROUP=1

MAX_TOKEN=
MAX_CHAT_ID=
MAX_USER_ID=


# ── 11. Защита от дублей и кэши. Обычно не трогать ──────────

# Если 1, бот будет требовать published_ids.json.
# Для GitHub Actions обычно оставить 0.
REQUIRE_PUBLISHED_CACHE=0

# Минимальные размеры текста для проверки дублей.
DUPLICATE_TEXT_MIN_WORDS=7
DUPLICATE_TEXT_MIN_CHARS=45
SOURCE_DUPLICATE_TEXT_MIN_WORDS=5
SOURCE_DUPLICATE_TEXT_MIN_CHARS=35
